ADDR=:8080
DATABASE_URL=postgres://{{DB_SLUG}}:{{DB_SLUG}}@localhost:5432/{{DB_SLUG}}?sslmode=disable
LOG_LEVEL=info
CORS_ORIGINS={{CORS}}

# Auth (ADR §7). JWT_SECRET has NO default — the process refuses to start without
# it. Generate one, e.g.: openssl rand -base64 48
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# argon2id password-hashing parameters (OWASP baseline; tune for your hardware).
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
