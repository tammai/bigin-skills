PORT=8080
DATABASE_URL=postgres://{{DB_SLUG}}:{{DB_SLUG}}@localhost:5432/{{DB_SLUG}}
LOG_LEVEL=info
CORS_ORIGINS={{CORS}}

# Auth — JWT_SECRET is required and has no default (fail-closed, same as DATABASE_URL)
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# argon2id password hashing (OWASP baseline: 19 MiB memory)
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Idempotency-Key store TTL
IDEMPOTENCY_KEY_TTL_HOURS=24
