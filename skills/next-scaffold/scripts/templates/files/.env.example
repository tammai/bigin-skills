# iron-session sealed-cookie secret, 32+ chars (generate one: openssl rand -base64 32)
# Used by src/lib/session.ts — required by the /api/backend proxy and (in the
# saas template) the login/signup/logout routes.
SESSION_PASSWORD=
# Backend REST API base URL (server-only; never exposed to the browser). The
# /api/backend/* proxy and the auth routes forward here. Point it at a running
# nodejs-scaffold (Fastify) or go-scaffold backend, e.g. http://localhost:8080
BACKEND_URL=
